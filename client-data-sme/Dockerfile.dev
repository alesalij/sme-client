# Этап разработки
FROM node:18-alpine

# Установка рабочей директории
WORKDIR /app

# Копирование файлов package
COPY package*.json ./

# Установка зависимостей
RUN npm install

# Копирование исходного кода
COPY . .

# Открытие порта разработки
EXPOSE 5173

# Запуск сервера разработки
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]