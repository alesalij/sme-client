# Server
PORT=3001
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:5173

# ===========================================
# External Services Configuration
# Format: SERVICE_KEY_DEV_URL and SERVICE_KEY_PROD_URL
# Automatically selects DEV or PROD based on NODE_ENV
# ===========================================

# Legal Entities API
LEGAL_ENTITIES_API_DEV_URL=http://localhost:4001
LEGAL_ENTITIES_API_PROD_URL=https://legal-entities-api.production.com

# Checks API
CHECKS_API_DEV_URL=http://localhost:4002
CHECKS_API_PROD_URL=https://checks-api.production.com

# Users API
USERS_API_DEV_URL=http://localhost:4003
USERS_API_PROD_URL=https://users-api.production.com

# Email (optional)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=alerts@example.com
EMAIL_PASS=password
EMAIL_FROM=SME Client<alerts@example.com>
EMAIL_TO=admin@example.com,devops@example.com

# Mattermost (optional)
MATTERMOST_WEBHOOK_URL=https://mattermost.example.com/hooks/xxx
MATTERMOST_CHANNEL=#alerts

LOG_DIR=./logs