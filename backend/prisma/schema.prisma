generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  passwordHash    String
  firstName       String
  lastName        String
  department      String
  role            Role      @default(USER)
  isActive        Boolean   @default(true)
  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  checkedEntities LegalEntity[] @relation("CheckedBy")
  checks          Check[]
  userActions     UserAction[]
}

enum Role {
  ADMIN
  AML_OFFICER
  RISK_OFFICER
  USER
}

model LegalEntity {
  id                  String    @id @default(uuid())
  inn                 String    @unique
  name                String
  fullName            String?
  address             String?
  director            String?
  activity            String?
  registrationDate    DateTime?
  status              LegalEntityStatus @default(PENDING)
  sparkData           Json?
  internalChecksData  Json?
  questionnaireData   Json?
  additionalData      String?
  consolidatedResult  ConsolidatedResult?
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  checkedBy           User?     @relation("CheckedBy", fields: [checkedById], references: [id])
  checkedById         String?
  
  checks              Check[]
  questionnaires      Questionnaire[]
  userActions         UserAction[]
}

enum LegalEntityStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  REJECTED
  NEEDS_INFO
}

enum ConsolidatedResult {
  SUCCESS
  NEEDS_ADDITIONAL_DATA
  FAILED
}

model Check {
  id                  String    @id @default(uuid())
  legalEntityId       String?
  legalEntity         LegalEntity? @relation(fields: [legalEntityId], references: [id], onDelete: Cascade)
  type                CheckType
  status              CheckStatus @default(PENDING)
  data                Json?
  result              String?
  performedAt         DateTime?
  performedById       String?
  performer           User?     @relation(fields: [performedById], references: [id])
  
  createdAt           DateTime  @default(now())
}

enum CheckType {
  SPARK
  INTERNAL_BASIC
  INTERNAL_EXTENDED
  CONSOLIDATED
  PERIODIC
}

enum CheckStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

model Questionnaire {
  id                  String    @id @default(uuid())
  legalEntityId       String
  legalEntity         LegalEntity @relation(fields: [legalEntityId], references: [id], onDelete: Cascade)
  data                Json
  generatedAt         DateTime  @default(now())
  signedAt            DateTime?
  signedBy            String?
  signedDocumentUrl   String?
  status              QuestionnaireStatus @default(GENERATED)
  
  createdAt           DateTime  @default(now())
}

enum QuestionnaireStatus {
  GENERATED
  SIGNED
  EXPIRED
  REVOKED
}

model UserAction {
  id                  String    @id @default(uuid())
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  legalEntityId       String?
  legalEntity         LegalEntity? @relation(fields: [legalEntityId], references: [id], onDelete: SetNull)
  actionType          ActionType
  details             Json?
  status              ActionStatus @default(IN_PROGRESS)
  ipAddress           String?
  userAgent           String?
  
  createdAt           DateTime  @default(now())
}

enum ActionType {
  SEARCH_INN
  SELECT_COMPANY
  SAVE_LEGAL_ENTITY
  SPARK_CHECK
  INTERNAL_CHECK
  CONSOLIDATED_CHECK
  SAVE_QUESTIONNAIRE
  UPLOAD_DOCUMENT
  PERIODIC_CHECK
  VIEW_LEGAL_ENTITY
  VIEW_DOCUMENT
  START_CHECKS
  LOGIN
  LOGOUT
  VIEW_LOGS
}

enum ActionStatus {
  IN_PROGRESS
  SUCCESS
  ERROR
  WARNING
}