// This is your Prisma schema file
// Используется ТОЛЬКО для чтения из view v_dm_person (без миграций, без изменений)

generator client {
 provider = "prisma-client-js"
 output   = "../node_modules/.prisma/client"
}

datasource db {
 provider = "postgresql"
 url      = env("DATABASE_URL")
}

// Представление v_dm_person (только для чтения)
model VDmPerson {
 id          Int       @id
 inn         String    @map("inn")
 ogrn        String?   @map("ogrn")
 name        String?   @map("name")
 fullName    String?   @map("full_name")
 type        String?   @map("type")
 status      String?   @map("status")
 regDate     DateTime? @map("reg_date")
 kpp         String?   @map("kpp")
 regAddress  String?   @map("reg_address")
 factAddress String?   @map("fact_address")
 ceo         String?   @map("ceo")
 beneficiary String?   @map("beneficiary")
 okved       String?   @map("okved")
 isResident  Boolean?  @map("is_resident")
 createdAt   DateTime? @map("created_at")
 updatedAt   DateTime? @map("updated_at")

 @@ignore
}
